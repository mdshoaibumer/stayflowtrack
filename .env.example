# StayFlow Track - Environment Configuration
# Copy this file to .env and fill in production values.
# NEVER commit the .env file to version control.

# Application
APP_ENV=production
APP_PORT=8080

# Domain
DOMAIN_API=api.yourdomain.com
DOMAIN_APP=app.yourdomain.com

# Database
DB_USER=stayflow
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_NAME=stayflow_track
DB_HOST=postgres
DB_PORT=5432
DB_SSL_MODE=require
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_MAX_LIFETIME=5m

# JWT (generate with: openssl rand -base64 64)
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_DIFFERENT
JWT_ISSUER=stayflow-track
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=168h

# Storage (MinIO / S3)
STORAGE_PROVIDER=s3
STORAGE_ENDPOINT=http://minio:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=stayflow-documents
STORAGE_ACCESS_KEY_ID=CHANGE_ME_MINIO_USER
STORAGE_SECRET_ACCESS_KEY=CHANGE_ME_MINIO_PASSWORD
STORAGE_USE_PATH_STYLE=true

# CORS
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Razorpay (optional - leave empty to disable)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Platform Admin (UUID of the platform operator tenant)
PLATFORM_TENANT_ID=

# Notification Webhook (generate with: openssl rand -hex 32)
NOTIFICATION_WEBHOOK_SECRET=

# Notification Provider (log|gupshup)
NOTIFICATION_PROVIDER=gupshup
GUPSHUP_API_KEY=
GUPSHUP_APP_NAME=

# Backups (optional)
BACKUP_DIR=/backups/postgres
RETENTION_DAYS=7
S3_BUCKET=
S3_PREFIX=stayflow-backups/postgres
