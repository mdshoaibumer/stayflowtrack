# StayFlow Track - Docker Daemon Configuration
# Install: sudo cp deploy/daemon.json /etc/docker/daemon.json
# Apply:   sudo systemctl restart docker

{
  "log-driver": "json-file",
  "log-opts": {
    "max-size": "10m",
    "max-file": "5"
  },
  "default-ulimits": {
    "nofile": {
      "Name": "nofile",
      "Hard": 65536,
      "Soft": 65536
    }
  }
}
